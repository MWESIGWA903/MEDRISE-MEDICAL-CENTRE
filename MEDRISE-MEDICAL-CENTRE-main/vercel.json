{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/medrise build:ssg",
  "outputDirectory": "artifacts/medrise/dist/public",
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "framework": null,
  "devCommand": null,
  "rewrites": [
    {
      "source": "/admin/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/staff/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/patient/(.*)",
      "destination": "/index.html"
    }
  ]
}
