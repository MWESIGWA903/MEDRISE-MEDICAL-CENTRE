{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/medrise build",
  "builds": [
    {
      "src": "artifacts/medrise/package.json",
      "use": "@vercel/static-build",
       "config": {
        "distDir": "dist/public"
      }
    }
  ]
}
