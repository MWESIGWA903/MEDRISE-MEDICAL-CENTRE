# ─── API Server ──────────────────────────────────────────────────────────────
# For local development (your machine's IP so physical phones can reach it)
# Run: ipconfig (Windows) or ifconfig (Mac/Linux) to find your IP
EXPO_PUBLIC_DOMAIN=localhost:8080
# If testing on a real phone on the same WiFi, use your machine's local IP:
# EXPO_PUBLIC_DOMAIN=192.168.1.100:8080
